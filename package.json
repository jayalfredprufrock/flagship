{
  "name": "@jayalfredprufrock/flagship",
  "version": "0.0.0-semantically-released",
  "description": "Tiny type-safe flag parser for node CLIs.",
  "homepage": "https://github.com/jayalfredprufrock/flagship#readme",
  "bugs": {
    "url": "https://github.com/jayalfredprufrock/flagship/issues"
  },
  "license": "MIT",
  "author": "Andrew Smiley <jayalfredprufrock@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayalfredprufrock/flagship.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "pnpm version ${nextRelease.version} --no-git-tag-version",
          "publishCmd": "pnpm publish --no-git-checks"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
